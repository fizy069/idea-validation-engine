# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored and must NEVER be committed.

# Required: OpenAI API key used by OASIS agents and the LLM judge.
OPENAI_API_KEY=

# Optional: override the OpenAI base URL (must start with https://).
# Useful for proxy services or Azure-style endpoints.
# OPENAI_API_BASE_URL=https://api.openai.com/v1
